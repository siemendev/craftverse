# Craftverse — local dev environment.
# Copy to `.env` (gitignored) and adjust as needed: `cp .env.example .env`.
# Used by docker-compose.yml. These are DEV-ONLY credentials — never reuse in prod.

# ---------------------------------------------------------------------------
# MariaDB (one instance, two databases: craftverse + keycloak)
# ---------------------------------------------------------------------------
# Root password (mariadb image MARIADB_ROOT_PASSWORD).
MARIADB_ROOT_PASSWORD=root
# Primary database + app user auto-created by the image; the init SQL
# (deploy/mariadb-init/01-init.sql) additionally creates the `keycloak` DB
# and grants the app user access to it.
MARIADB_DATABASE=craftverse
MARIADB_USER=app
MARIADB_PASSWORD=app

# ---------------------------------------------------------------------------
# Keycloak (dev mode, start-dev --import-realm)
# ---------------------------------------------------------------------------
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
# Keycloak connects to MariaDB. KC_DB=mariadb is set in compose.
KC_DB_URL_HOST=mariadb
KC_DB_URL_DATABASE=keycloak
KC_DB_USERNAME=app
KC_DB_PASSWORD=app

# ---------------------------------------------------------------------------
# Backend (Go) — see CONTRACTS.md "Environment variables (backend)"
# ---------------------------------------------------------------------------
CRAFTVERSE_HTTP_ADDR=:8080
# go-sql-driver/mysql DSN. mariadb is the compose service name.
CRAFTVERSE_DB_DSN=app:app@tcp(mariadb:3306)/craftverse?parseTime=true&loc=UTC
# OIDC issuer — must match the token issuer the SPA gets. In local dev the SPA
# talks to Keycloak through Traefik at http://auth.localhost, but the backend
# validates tokens server-side and reaches Keycloak in-cluster. The issuer in
# the token is determined by KC_HOSTNAME below; both the browser host and the
# in-container host resolve to the craftverse realm. We use the internal host
# for the issuer the backend trusts.
CRAFTVERSE_OIDC_ISSUER=http://keycloak:8080/realms/craftverse
CRAFTVERSE_OIDC_AUDIENCE=craftverse-web
CRAFTVERSE_CORS_ORIGINS=http://craftverse.localhost

# ---------------------------------------------------------------------------
# Frontend (Vite, VITE_ prefix)
# ---------------------------------------------------------------------------
VITE_API_BASE_URL=/api
VITE_OIDC_AUTHORITY=http://auth.localhost/realms/craftverse
VITE_OIDC_CLIENT_ID=craftverse-web
VITE_OIDC_REDIRECT_URI=http://craftverse.localhost/
