# Frontend env (Vite). All optional — see src/lib/config.ts for resolution.
# In production these can also be supplied at runtime via /config.js
# (window.__CRAFTVERSE_CONFIG__), rendered by docker-entrypoint.sh.

# API base path/URL. Default "/api".
VITE_API_BASE_URL=/api

# OIDC (Keycloak). Leave VITE_OIDC_AUTHORITY empty to run WITHOUT an auth gate
# (local bring-up before Keycloak is ready).
VITE_OIDC_AUTHORITY=
VITE_OIDC_CLIENT_ID=craftverse-web
VITE_OIDC_REDIRECT_URI=http://craftverse.localhost/

# Dev-only: where the Vite dev server proxies /api to.
VITE_DEV_API_TARGET=http://localhost:8080
